aop_framework:AdverseOutcome a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "AdverseOutcome" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aop_framework:outcome_level ],
        [ a owl:Restriction ;
            owl:allValuesFrom owg:OutcomeLevelEnum ;
            owl:onProperty aop_framework:outcome_level ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aop_framework:occurs_in_anatomy ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aop_framework:occurs_in_anatomy ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty aop_framework:aopwiki_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aop_framework:biological_process ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aop_framework:outcome_level ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:Uriorcurie ;
            owl:onProperty aop_framework:occurs_in_anatomy ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:Uriorcurie ;
            owl:onProperty aop_framework:biological_process ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aop_framework:aopwiki_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aop_framework:aopwiki_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aop_framework:biological_process ],
        aop_framework:NamedThing ;
    skos:definition "An adverse health outcome at the organism or population level that represents the apical endpoint of an Adverse Outcome Pathway. This is the final, clinically or ecologically relevant effect." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/aop_framework> .

aop_framework:AdverseOutcomePathway a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "AdverseOutcomePathway" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aop_framework:adverse_outcome ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aop_framework:adverse_outcome ],
        [ a owl:Restriction ;
            owl:allValuesFrom aop_framework:AdverseOutcome ;
            owl:onProperty aop_framework:adverse_outcome ],
        [ a owl:Restriction ;
            owl:allValuesFrom aop_framework:KeyEventRelationship ;
            owl:onProperty aop_framework:key_event_relationships ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aop_framework:aopwiki_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aop_framework:key_event_relationships ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aop_framework:aopwiki_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aop_framework:molecular_initiating_event ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aop_framework:key_events ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty aop_framework:aopwiki_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom aop_framework:KeyEvent ;
            owl:onProperty aop_framework:key_events ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aop_framework:stressors ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty aop_framework:stressors ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aop_framework:molecular_initiating_event ],
        [ a owl:Restriction ;
            owl:allValuesFrom aop_framework:MolecularInitiatingEvent ;
            owl:onProperty aop_framework:molecular_initiating_event ],
        aop_framework:NamedThing ;
    skos:definition "A sequence of causally linked events at different levels of biological organization that lead from a molecular initiating event through intermediate key events to an adverse health outcome. AOPs provide a structured framework for organizing mechanistic evidence." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/aop_framework> .

aop_framework:KeyEventRelationship a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "KeyEventRelationship" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aop_framework:downstream_event ],
        [ a owl:Restriction ;
            owl:allValuesFrom owg:QuantitativeUnderstandingEnum ;
            owl:onProperty aop_framework:quantitative_understanding ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aop_framework:relationship_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aop_framework:quantitative_understanding ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aop_framework:downstream_event ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aop_framework:relationship_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aop_framework:quantitative_understanding ],
        [ a owl:Restriction ;
            owl:allValuesFrom aop_framework:KeyEvent ;
            owl:onProperty aop_framework:downstream_event ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aop_framework:evidence_support ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aop_framework:upstream_event ],
        [ a owl:Restriction ;
            owl:allValuesFrom owg:EvidenceSupportEnum ;
            owl:onProperty aop_framework:evidence_support ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aop_framework:evidence_support ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty aop_framework:relationship_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aop_framework:upstream_event ],
        [ a owl:Restriction ;
            owl:allValuesFrom aop_framework:KeyEvent ;
            owl:onProperty aop_framework:upstream_event ],
        aop_framework:NamedThing ;
    skos:definition "A directional relationship between two key events in an AOP. Represents the causal linkage between an upstream event and a downstream event with supporting evidence." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/aop_framework> .

aop_framework:MolecularInitiatingEvent a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "MolecularInitiatingEvent" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aop_framework:target_molecule ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty aop_framework:target_molecule ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aop_framework:target_molecule ],
        aop_framework:KeyEvent ;
    skos:definition "The initial molecular-level perturbation that starts an Adverse Outcome Pathway. The MIE is the direct interaction between a stressor and a biological target (e.g., receptor binding, enzyme inhibition)." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/aop_framework> .

aop_framework:downstream_key_events a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "downstream_key_events" ;
    rdfs:range aop_framework:KeyEvent ;
    skos:definition "Key events that follow this key event (downstream in the pathway)." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/aop_framework> .

aop_framework:key_event_relationships a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "key_event_relationships" ;
    rdfs:range aop_framework:KeyEventRelationship ;
    skos:definition "The key event relationships connecting events in this AOP." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/aop_framework> .

aop_framework:stressors a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "stressors" ;
    rdfs:range linkml:String ;
    skos:definition "Chemical or physical stressors that can trigger this AOP." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/aop_framework> .

aop_framework:upstream_key_events a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "upstream_key_events" ;
    rdfs:range aop_framework:KeyEvent ;
    skos:definition "Key events that lead to this key event (upstream in the pathway)." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/aop_framework> .

