        linkml:ClassDefinition ;
    rdfs:label "ExposureCondition" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:exposure_concentration ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:exposure_agent ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_base:QuantityValue ;
            owl:onProperty assay_base:exposure_concentration ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_base:QuantityValue ;
            owl:onProperty assay_base:timing_post_exposure ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:timing_post_exposure ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:exposure_concentration ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_base:QuantityValue ;
            owl:onProperty assay_base:exposure_duration ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_base:NamedEntity ;
            owl:onProperty assay_base:exposure_agent ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:exposure_agent ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:timing_post_exposure ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:exposure_duration ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:exposure_duration ],
        assay_base:NamedEntity ;
    skos:definition "A structured description of an exposure or treatment applied to a biological system. Captures what agent was applied, at what concentration, for how long, and when the measurement was taken relative to exposure." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

assay_base:MediumSupplement a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "MediumSupplement" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty assay_base:manufacturer ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:manufacturer ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:supplement_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom owg:SupplementTypeEnum ;
            owl:onProperty assay_base:supplement_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:supplement_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:concentration ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:manufacturer ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:concentration ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:catalog_number ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty assay_base:catalog_number ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_base:QuantityValue ;
            owl:onProperty assay_base:concentration ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:catalog_number ],
        assay_base:NamedEntity ;
    skos:definition "Supplement or additive to cell culture medium." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

assay_base:PopulationSubject a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "PopulationSubject" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:inclusion_criteria ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty assay_base:inclusion_criteria ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:cohort_size ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:age_range ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:Integer ;
            owl:onProperty assay_base:cohort_size ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_base:QuantityRange ;
            owl:onProperty assay_base:age_range ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:subjects ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_base:InVivoSubject ;
            owl:onProperty assay_base:subjects ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:inclusion_criteria ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:cohort_size ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:age_range ],
        assay_base:StudySubject ;
    skos:definition "A population or cohort of subjects studied in aggregate. Used for epidemiological or population-level analyses. Can optionally hold references to individual InVivoSubject members." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

assay_base:equipment_required a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "equipment_required" ;
    rdfs:range linkml:String ;
    skos:definition "Equipment required for this protocol." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

assay_base:follows_protocols a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "follows_protocols" ;
    rdfs:range assay_base:Protocol ;
    skos:definition "The Protocol(s) that this assay follows. Any Protocol or Protocol subclass (ImagingProtocol, StainingProtocol, SpirometryProtocol, MolecularAssayProtocol) is valid. Use this for general protocol references; assay subclasses also have typed protocol slots for domain-specific protocols." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

assay_base:has_exposure_condition a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "has_exposure_condition" ;
    rdfs:range assay_base:ExposureCondition ;
    skos:definition "The exposure condition(s) applied to the study subject. Captures the agent, concentration, duration, and timing of exposure/treatment. Multivalued to support co-exposures or dose-response series." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

assay_base:primer_sequences a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "primer_sequences" ;
    rdfs:range linkml:String ;
    skos:definition "Primer sequences used for PCR-based methods." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

assay_base:sub_protocols a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "sub_protocols" ;
    rdfs:range assay_base:Protocol ;
    skos:definition "Other protocols that are part of this protocol's workflow. Use this to compose protocols from reusable steps (e.g., sample preparation, wash steps, fixation, post-processing). Any Protocol or Protocol subclass is valid." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

assay_base:subjects a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "subjects" ;
    rdfs:range assay_base:InVivoSubject ;
    skos:definition "Individual subjects in the population or cohort. Optional — use when individual-level data is available alongside aggregate cohort metadata." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

assay_base:supplements a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "supplements" ;
    rdfs:range assay_base:MediumSupplement ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

assay_microschemas:ASLAssay a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "ASLAssay" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:has_specified_output ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:has_specified_output ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_microschemas:ASLOutput ;
            owl:onProperty assay_base:has_specified_output ],
        assay_base:Assay ;
    skos:definition "Assay for measuring airway surface liquid properties including ASL height, periciliary layer depth, and ion composition. Informs on Key Event: \"Decreased ASL height\" or \"Altered airway hydration\" in CF-related AOPs." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_microschemas> .

assay_microschemas:BALFSputumAssay a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "BALFSputumAssay" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:target_cell_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_microschemas:BALFSputumOutput ;
            owl:onProperty assay_base:has_specified_output ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:study_subject ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:has_specified_output ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_base:NamedEntity ;
            owl:onProperty assay_base:target_cell_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:has_specified_output ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_base:InVivoSubject ;
            owl:onProperty assay_base:study_subject ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:target_cell_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:study_subject ],
        assay_base:Assay ;
    skos:definition """Assay for measuring bronchoalveolar lavage fluid (BALF) or sputum composition. Informs on Key Event: "Airway inflammation" and provides evidence for inflammatory cell populations and cytokine levels.
This assay is IN VIVO ONLY - requires samples from human or animal subjects.""" ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_microschemas> ;
    owg:supported_contexts "in_vivo_only" .

assay_microschemas:CFTRFunctionAssay a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "CFTRFunctionAssay" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:has_specified_output ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_microschemas:stimulation_agent ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty assay_microschemas:inhibitor_used ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_microschemas:stimulation_agent ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_microschemas:CFTRFunctionOutput ;
            owl:onProperty assay_base:has_specified_output ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_microschemas:inhibitor_used ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty assay_microschemas:stimulation_agent ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_microschemas:inhibitor_used ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:has_specified_output ],
        assay_base:Assay ;
    skos:definition "Assay for measuring CFTR (Cystic Fibrosis Transmembrane Conductance Regulator) function. Informs on Key Event: \"Decreased CFTR function\" in cystic fibrosis-related AOPs." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_microschemas> .

assay_microschemas:CiliaryFunctionAssay a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "CiliaryFunctionAssay" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty assay_microschemas:airway_region ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:has_specified_output ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty assay_microschemas:analysis_software ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_base:StudySubject ;
            owl:onProperty assay_base:study_subject ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:study_subject ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_microschemas:airway_region ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_microschemas:analysis_software ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_microschemas:CiliaryFunctionOutput ;
            owl:onProperty assay_base:has_specified_output ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_microschemas:analysis_software ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_microschemas:airway_region ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:study_subject ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:has_specified_output ],
        assay_base:Assay ;
    skos:definition """Assay for measuring ciliary function including beat frequency, active area, cilia morphology, and ciliated cell populations. Informs on Key Event: "Decreased ciliary function" in respiratory AOPs.
CONTEXT: Can be performed in vitro (tissue slices, spheroids) or in vivo (often using optical coherence tomography).
TIER 1 slots (critical): beat_frequency_hz, active_area_percentage, cilia_length, cilia_per_cell, percentage_ciliated_cells, cell_type_ratios,""" ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_microschemas> ;
    owg:supported_contexts "in_vitro_or_in_vivo" .

assay_microschemas:EGFRSignalingAssay a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "EGFRSignalingAssay" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_microschemas:phosphorylation_site ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_microschemas:EGFRSignalingOutput ;
            owl:onProperty assay_base:has_specified_output ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:has_specified_output ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_microschemas:normalization_reference ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty assay_microschemas:normalization_reference ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_microschemas:normalization_reference ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty assay_microschemas:phosphorylation_site ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_microschemas:phosphorylation_site ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:has_specified_output ],
        assay_base:Assay ;
    skos:definition """Assay for measuring EGFR phosphorylation and downstream signaling. Informs on Key Event: "EGFR activation" in mucus hypersecretion AOPs.
IMPORTANT: EGFR phosphorylation is the MOST SPECIFIC evidence for activation. Downstream kinase data alone is insufficient - needs phosphorylation measure OR inhibitor reversal for strong evidence. Cell type matters due to receptor location in ALI cultures.
TIER 1 slots (critical): egfr_phosphorylation with site specification.""" ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_microschemas> .

assay_microschemas:FoxJExpressionAssay a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "FoxJExpressionAssay" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:has_specified_output ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:has_specified_output ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_microschemas:FoxJExpressionOutput ;
            owl:onProperty assay_base:has_specified_output ],
        assay_base:Assay ;
    skos:definition """Assay for measuring FoxJ1 expression related to ciliogenesis. Informs on Key Event: "Altered ciliogenesis" in respiratory AOPs. FoxJ1 is a master transcription factor for motile cilia.
This assay is primarily IN VITRO focused.""" ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_microschemas> ;
    owg:supported_contexts "in_vitro_only" .

assay_microschemas:GeneExpressionAssay a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "GeneExpressionAssay" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty assay_microschemas:gene_expression_method ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:has_specified_output ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_microschemas:gene_expression_method ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_microschemas:normalization_reference ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_microschemas:normalization_reference ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_microschemas:target_gene ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty assay_microschemas:normalization_reference ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_microschemas:target_gene ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_microschemas:gene_expression_method ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:has_specified_output ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_microschemas:GeneExpressionOutput ;
            owl:onProperty assay_base:has_specified_output ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:Uriorcurie ;
            owl:onProperty assay_microschemas:target_gene ],
        assay_base:Assay ;
    skos:definition "General assay for gene expression measurements. Renamed from TranscriptionFactorExpressionMeasurement per domain feedback - gene expression is more commonly the primary output." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_microschemas> ;
    owg:supported_contexts "in_vitro_only" .

assay_microschemas:GobletCellAssay a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "GobletCellAssay" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:has_specified_output ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:has_specified_output ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_microschemas:GobletCellOutput ;
            owl:onProperty assay_base:has_specified_output ],
        assay_base:Assay ;
    skos:definition """Assay for measuring goblet cell populations and mucin production. Informs on Key Event: "Goblet cell hyperplasia" or "Mucin hypersecretion".
IMPORTANT per domain feedback: Need BOTH cell counts AND mucin secretion measurements - cells may stay same but secretion changes. AB-PAS staining common for visualizing goblet cells. Some secreted mucins not tethered to goblet cells.""" ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_microschemas> .

assay_microschemas:LungFunctionAssay a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "LungFunctionAssay" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:study_subject ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_microschemas:recent_respiratory_illness ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:study_subject ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_microschemas:LungFunctionOutput ;
            owl:onProperty assay_base:has_specified_output ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_microschemas:hemoglobin_level ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_microschemas:recent_respiratory_illness ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:has_specified_output ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_microschemas:reference_dataset ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_microschemas:hemoglobin_level ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty assay_microschemas:recent_respiratory_illness ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_base:InVivoSubject ;
            owl:onProperty assay_base:study_subject ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty assay_microschemas:reference_dataset ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_microschemas:reference_dataset ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:has_specified_output ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_base:QuantityValue ;
            owl:onProperty assay_microschemas:hemoglobin_level ],
        assay_base:Assay ;
    skos:definition """Clinical assay for measuring lung function. Informs on Adverse Outcome: "Decreased lung function" - the composite clinical outcome.
IMPORTANT per domain feedback: - Subject characteristics (sex, species, age, height) are critical -
  often reported as % of predicted baseline
- Reference dataset (GLI-2012 for humans) is essential for interpretation - Hemoglobin levels pair with DLCO measurements - Recent respiratory illness affects spirometry results
TIER 1 slots (critical): fev1, fvc, subject_characteristics, reference_dataset. This assay is IN VIVO ONLY.""" ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_microschemas> ;
    owg:supported_contexts "in_vivo_only" .

assay_microschemas:MucociliaryClearanceAssay a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "MucociliaryClearanceAssay" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:has_specified_output ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:has_specified_output ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty assay_microschemas:mucus_composition ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_microschemas:MucociliaryClearanceOutput ;
            owl:onProperty assay_base:has_specified_output ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_microschemas:mucus_composition ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_microschemas:mucus_composition ],
        assay_base:Assay ;
    skos:definition "Assay for measuring mucociliary clearance and transport. Informs on Key Event: \"Impaired mucociliary clearance\" in respiratory AOPs. TIER 1 slots (critical): transport_rate, directionality." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_microschemas> .

assay_microschemas:OxidativeStressAssay a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "OxidativeStressAssay" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_microschemas:ros_probe_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:has_specified_output ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:has_specified_output ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty assay_microschemas:ros_probe_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_microschemas:ros_probe_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_microschemas:OxidativeStressOutput ;
            owl:onProperty assay_base:has_specified_output ],
        assay_base:Assay ;
    skos:definition "Assay for measuring oxidative stress markers. Informs on Key Event: \"Increased oxidative stress\" - often a Molecular Initiating Event (MIE) in respiratory toxicology AOPs. TIER 1 slots (critical): All surrogate markers for oxidative stress. Multiple detection methods expected - no single \"best\" for lung function." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_microschemas> .

assay_microschemas:pathway_biomarkers a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "pathway_biomarkers" ;
    rdfs:range linkml:String ;
    skos:definition "Pathway-specific biomarker signatures. TIER 2 - relationship to outcome needs further investigation." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_microschemas> .

assay_microschemas:protein_oxidation_markers a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "protein_oxidation_markers" ;
