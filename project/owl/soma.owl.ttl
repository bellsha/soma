owg:adverse_outcome_pathways a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "adverse_outcome_pathways" ;
    rdfs:range aop_framework:AdverseOutcomePathway ;
    skos:definition "Collection of Adverse Outcome Pathways. AOPs describe sequences of causally linked events from molecular initiating events to adverse outcomes." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/soma> .

owg:asl_assays a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "asl_assays" ;
    rdfs:range assay_microschemas:ASLAssay ;
    skos:definition "Collection of airway surface liquid assays. Informs on Key Event: \"Decreased ASL height\" or \"Altered airway hydration\"." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/soma> .

owg:balf_sputum_assays a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "balf_sputum_assays" ;
    rdfs:range assay_microschemas:BALFSputumAssay ;
    skos:definition "Collection of BALF and sputum assays. In vivo only. Informs on Key Event: \"Airway inflammation\"." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/soma> .

owg:cftr_assays a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "cftr_assays" ;
    rdfs:range assay_microschemas:CFTRFunctionAssay ;
    skos:definition "Collection of CFTR function assays. Informs on Key Event: \"Decreased CFTR function\"." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/soma> .

owg:ciliary_function_assays a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "ciliary_function_assays" ;
    rdfs:range assay_microschemas:CiliaryFunctionAssay ;
    skos:definition "Collection of ciliary function assays. Informs on Key Event: \"Decreased ciliary function\". Contains named slots for beat frequency, active area, cilia length, etc." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/soma> .

owg:egfr_signaling_assays a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "egfr_signaling_assays" ;
    rdfs:range assay_microschemas:EGFRSignalingAssay ;
    skos:definition "Collection of EGFR signaling assays. Informs on Key Event: \"EGFR activation\". Note: EGFR phosphorylation is the most specific evidence for activation." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/soma> .

owg:foxj_assays a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "foxj_assays" ;
    rdfs:range assay_microschemas:FoxJExpressionAssay ;
    skos:definition "Collection of FoxJ1/ciliogenesis assays. Informs on Key Event: \"Altered ciliogenesis\"." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/soma> .

owg:gene_expression_assays a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "gene_expression_assays" ;
    rdfs:range assay_microschemas:GeneExpressionAssay ;
    skos:definition "Collection of gene expression assays. Generic assay for gene/protein expression measurements." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/soma> .

owg:goblet_cell_assays a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "goblet_cell_assays" ;
    rdfs:range assay_microschemas:GobletCellAssay ;
    skos:definition "Collection of goblet cell and mucin assays. Informs on Key Event: \"Goblet cell hyperplasia\" or \"Mucin hypersecretion\". Combined from previous GobletCellMeasurement and MucinProductionMeasurement." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/soma> .

owg:lung_function_assays a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "lung_function_assays" ;
    rdfs:range assay_microschemas:LungFunctionAssay ;
    skos:definition "Collection of lung function assays. In vivo only. Informs on Adverse Outcome: \"Decreased lung function\" - the composite clinical outcome." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/soma> .

owg:mcc_assays a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "mcc_assays" ;
    rdfs:range assay_microschemas:MucociliaryClearanceAssay ;
    skos:definition "Collection of mucociliary clearance assays. Informs on Key Event: \"Impaired mucociliary clearance\"." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/soma> .

owg:oxidative_stress_assays a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "oxidative_stress_assays" ;
    rdfs:range assay_microschemas:OxidativeStressAssay ;
    skos:definition "Collection of oxidative stress assays. Informs on Key Event: \"Increased oxidative stress\" - often a Molecular Initiating Event." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/soma> .

owg:protocols a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "protocols" ;
    rdfs:range assay_base:Protocol ;
    skos:definition "Collection of protocols. Contains Tier 2/3 procedural details important for reproducibility." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/soma> .

aop_framework:adverse_outcome a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "adverse_outcome" ;
    rdfs:range aop_framework:AdverseOutcome ;
    skos:definition "The adverse outcome that is the apical endpoint of this AOP." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/aop_framework> .

aop_framework:biological_action a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "biological_action" ;
    rdfs:range owg:BiologicalActionEnum ;
    skos:definition "The type of change (increased, decreased, altered, impaired)." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/aop_framework> .

aop_framework:biological_object a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "biological_object" ;
    rdfs:range linkml:String ;
    skos:definition "The biological entity affected (protein, cell, tissue, organ)." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/aop_framework> .

aop_framework:description a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "description" ;
    rdfs:range linkml:String ;
    skos:definition "A detailed description of the entity." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/aop_framework> .

aop_framework:downstream_event a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "downstream_event" ;
    rdfs:range aop_framework:KeyEvent ;
    skos:definition "The downstream key event in this relationship (effect)." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/aop_framework> .

aop_framework:evidence_support a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "evidence_support" ;
    rdfs:range owg:EvidenceSupportEnum ;
    skos:definition "Level of evidence supporting this key event relationship." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/aop_framework> .

aop_framework:level_of_biological_organization a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "level_of_biological_organization" ;
    rdfs:range owg:BiologicalOrganizationLevelEnum ;
    skos:definition "The level of biological organization at which this key event occurs." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/aop_framework> .

aop_framework:molecular_initiating_event a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "molecular_initiating_event" ;
    rdfs:range aop_framework:MolecularInitiatingEvent ;
    skos:definition "The molecular initiating event that starts this AOP." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/aop_framework> .

aop_framework:occurs_in_cell_type a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "occurs_in_cell_type" ;
    rdfs:range linkml:Uriorcurie ;
    skos:definition "The cell type in which this key event occurs. Should reference a Cell Ontology (CL) term." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/aop_framework> .

aop_framework:outcome_level a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "outcome_level" ;
    rdfs:range owg:OutcomeLevelEnum ;
    skos:definition "The level at which the adverse outcome manifests (individual, population)." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/aop_framework> .

aop_framework:quantitative_understanding a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "quantitative_understanding" ;
    rdfs:range owg:QuantitativeUnderstandingEnum ;
    skos:definition "Level of quantitative understanding of the relationship." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/aop_framework> .

aop_framework:relationship_type a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "relationship_type" ;
    rdfs:range linkml:String ;
    skos:definition "The type of causal relationship (directly leads to, indirectly leads to)." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/aop_framework> .

aop_framework:target_molecule a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "target_molecule" ;
    rdfs:range linkml:String ;
    skos:definition "The molecular target of the stressor in the MIE (e.g., receptor, enzyme)." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/aop_framework> .

aop_framework:upstream_event a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "upstream_event" ;
    rdfs:range aop_framework:KeyEvent ;
    skos:definition "The upstream key event in this relationship (cause)." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/aop_framework> .

