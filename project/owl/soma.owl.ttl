@prefix CHEBI: <http://purl.obolibrary.org/obo/CHEBI_> .
@prefix ECTO: <http://purl.obolibrary.org/obo/ECTO_> .
@prefix IAO: <http://purl.obolibrary.org/obo/IAO_> .
@prefix OBI: <http://purl.obolibrary.org/obo/OBI_> .
@prefix aop_framework: <https://w3id.org/EHS-Data-Standards/aop_framework/> .
@prefix assay_base: <https://w3id.org/EHS-Data-Standards/assay_base/> .
@prefix assay_microschemas: <https://w3id.org/EHS-Data-Standards/assay_microschemas/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix linkml: <https://w3id.org/linkml/> .
@prefix owg: <https://w3id.org/EHS-Data-Standards/soma/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

assay_base:general_procedure a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "general_procedure" ;
    rdfs:range linkml:String ;
    skos:definition "High-level description of the procedure." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

assay_base:key_reagents a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "key_reagents" ;
    rdfs:range linkml:String ;
    skos:definition "Key reagents needed for this protocol." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

assay_base:obi_mapping a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "obi_mapping" ;
    rdfs:range linkml:Uriorcurie ;
    skos:definition "OBI ontology term for this method." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

assay_base:sop_reference a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "sop_reference" ;
    rdfs:range linkml:String ;
    skos:definition "Reference to standard operating procedure document." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

assay_microschemas:detection_method_details a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "detection_method_details" ;
    rdfs:range linkml:String ;
    skos:definition "Detection method details. TIER 1 per feedback - expected to have multiple detection methods." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_microschemas> .

assay_microschemas:imaging_protocol a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "imaging_protocol" ;
    rdfs:range assay_base:ImagingProtocol ;
    skos:definition "Reference to the imaging protocol used. TIER 1 for CBF, ASL assays." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_microschemas> .

assay_microschemas:molecular_protocol a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "molecular_protocol" ;
    rdfs:range assay_base:MolecularAssayProtocol ;
    skos:definition "Reference to the molecular assay protocol used." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_microschemas> .

assay_microschemas:spirometry_protocol a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "spirometry_protocol" ;
    rdfs:range assay_base:SpirometryProtocol ;
    skos:definition "Reference to the spirometry protocol used." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_microschemas> .

assay_microschemas:staining_protocol a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "staining_protocol" ;
    rdfs:range assay_base:StainingProtocol ;
    skos:definition "Reference to staining protocol (AB-PAS, immunochem). TIER 1." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_microschemas> .

owg:Container a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "Container" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom assay_base:Protocol ;
            owl:onProperty owg:protocols ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty owg:mcc_assays ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_microschemas:FoxJExpressionAssay ;
            owl:onProperty owg:foxj_assays ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_microschemas:CiliaryFunctionAssay ;
            owl:onProperty owg:ciliary_function_assays ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty owg:oxidative_stress_assays ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty owg:egfr_signaling_assays ],
        [ a owl:Restriction ;
            owl:allValuesFrom aop_framework:KeyEvent ;
            owl:onProperty aop_framework:key_events ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_microschemas:BALFSputumAssay ;
            owl:onProperty owg:balf_sputum_assays ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_microschemas:OxidativeStressAssay ;
            owl:onProperty owg:oxidative_stress_assays ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty owg:gene_expression_assays ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_microschemas:MucociliaryClearanceAssay ;
            owl:onProperty owg:mcc_assays ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_microschemas:GeneExpressionAssay ;
            owl:onProperty owg:gene_expression_assays ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_microschemas:EGFRSignalingAssay ;
            owl:onProperty owg:egfr_signaling_assays ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_microschemas:CFTRFunctionAssay ;
            owl:onProperty owg:cftr_assays ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_microschemas:LungFunctionAssay ;
            owl:onProperty owg:lung_function_assays ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty owg:lung_function_assays ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty owg:protocols ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty owg:foxj_assays ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aop_framework:key_events ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_microschemas:ASLAssay ;
            owl:onProperty owg:asl_assays ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty owg:balf_sputum_assays ],
        [ a owl:Restriction ;
            owl:allValuesFrom aop_framework:AdverseOutcomePathway ;
            owl:onProperty owg:adverse_outcome_pathways ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty owg:goblet_cell_assays ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_microschemas:GobletCellAssay ;
            owl:onProperty owg:goblet_cell_assays ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty owg:cftr_assays ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty owg:adverse_outcome_pathways ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty owg:asl_assays ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty owg:ciliary_function_assays ] ;
    skos:definition """Root container for outcomes research data. Organized around ASSAYS that inform on Key Events in Adverse Outcome Pathways (AOPs).
The schema is assay-centric: each assay class contains named slots for its specific measurements, with an explicit connection to the Key Event it informs via the informs_on_key_event slot.""" ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/soma> .

assay_microschemas:ASLOutput a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "ASLOutput" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_microschemas:mucus_layer_thickness ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_microschemas:periciliary_layer_depth ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_microschemas:asl_ph ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty assay_microschemas:ion_composition ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_base:QuantityValue ;
            owl:onProperty assay_microschemas:asl_ph ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_base:QuantityValue ;
            owl:onProperty assay_microschemas:mucus_layer_thickness ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_base:QuantityValue ;
            owl:onProperty assay_microschemas:periciliary_layer_depth ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_microschemas:mucus_layer_thickness ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_microschemas:asl_ph ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_microschemas:periciliary_layer_depth ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_microschemas:asl_height_um ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_microschemas:ion_composition ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_base:QuantityValue ;
            owl:onProperty assay_microschemas:asl_height_um ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_microschemas:ion_composition ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_microschemas:asl_height_um ],
        assay_base:AssayOutputMeasurement ;
    skos:definition "Measurement results from an airway surface liquid assay. Contains the measured values for ASL height, periciliary layer depth, and ion composition." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_microschemas> .

