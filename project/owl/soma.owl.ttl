        linkml:SlotDefinition ;
    rdfs:label "total_lung_capacity" ;
    rdfs:range assay_base:QuantityValue ;
    skos:definition "Total lung capacity. TIER 3 - requires more equipment." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_microschemas> .

assay_microschemas:total_protein_concentration a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "total_protein_concentration" ;
    rdfs:range assay_base:QuantityValue ;
    skos:definition "Total protein concentration." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_microschemas> .

assay_microschemas:transport_directionality a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "transport_directionality" ;
    rdfs:range owg:DirectionalityEnum ;
    skos:definition "Directionality of mucociliary transport. TIER 1." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_microschemas> .

assay_microschemas:transport_rate a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "transport_rate" ;
    rdfs:range assay_base:QuantityValue ;
    skos:definition "Mucociliary transport rate. TIER 1 - primary outcome measure for MCC assays." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_microschemas> .

aop_framework:key_events a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "key_events" ;
    rdfs:range aop_framework:KeyEvent ;
    skos:definition "The key events in this AOP (intermediate events between MIE and AO)." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/aop_framework> .

assay_base:QuantityRange a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "QuantityRange" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:min_value ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_base:QuantityValue ;
            owl:onProperty assay_base:min_value ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_base:Unit ;
            owl:onProperty assay_base:unit ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:unit ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:max_value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:min_value ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_base:QuantityValue ;
            owl:onProperty assay_base:max_value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:unit ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:max_value ] ;
    skos:definition "A range of quantity values with minimum and maximum bounds." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

assay_base:antibodies_used a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "antibodies_used" ;
    rdfs:range linkml:String ;
    skos:definition "Antibodies used in staining or detection." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

assay_base:cell_type_ratios a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "cell_type_ratios" ;
    rdfs:range linkml:String ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

aop_framework:biological_process a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "biological_process" ;
    rdfs:range linkml:Uriorcurie ;
    skos:definition "The biological process affected by this key event. Should reference a GO biological process term." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/aop_framework> .

aop_framework:occurs_in_anatomy a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "occurs_in_anatomy" ;
    rdfs:range linkml:Uriorcurie ;
    skos:definition "The anatomical location where this key event occurs. Should reference a UBERON anatomy term." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/aop_framework> .

assay_base:InVivoSubject a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "InVivoSubject" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:collection_date ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:sex ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:collection_date ],
        [ a owl:Restriction ;
            owl:allValuesFrom owg:SampleTypeEnum ;
            owl:onProperty assay_base:sample_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:disease_state ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:age ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:age ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:sample_collection_method ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:subject_characteristics ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty assay_base:collection_site ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty assay_base:disease_state ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:clinical_context ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:subject_characteristics ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:sample_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:collection_site ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:sample_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty assay_base:clinical_context ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:sample_collection_method ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:collection_site ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty assay_base:sample_collection_method ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:clinical_context ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_base:QuantityValue ;
            owl:onProperty assay_base:age ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:Date ;
            owl:onProperty assay_base:collection_date ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:sex ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:disease_state ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty assay_base:sex ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty assay_base:subject_characteristics ],
        assay_base:StudySubject ;
    skos:definition "A living human or animal subject from whom measurements are taken. Used for clinical assays (lung function, BALF/sputum) and any assay performed on living subjects." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

assay_base:cell_culture_growth_mode a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "cell_culture_growth_mode" ;
    rdfs:range owg:CellCultureGrowthModeEnum ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

assay_base:cell_type a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "cell_type" ;
    rdfs:range assay_base:NamedEntity ;
    skos:definition "The cell type being studied. Reference to a Cell Ontology (CL) term. Used on CellularSystem and CellLine to describe the cell identity." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

assay_base:culture_media a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "culture_media" ;
    rdfs:range assay_base:CellCultureMedium ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

assay_base:detection_method a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "detection_method" ;
    rdfs:range linkml:String ;
    skos:definition "Detection method used (e.g., flow cytometry, plate reader)." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

assay_base:disease_state a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "disease_state" ;
    rdfs:range linkml:String ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

assay_base:manufacturer a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "manufacturer" ;
    rdfs:range linkml:String ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

assay_base:model_species a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "model_species" ;
    rdfs:range assay_base:NamedEntity ;
    skos:definition "The species of origin for the cells or organism being studied. Reference to NCBITaxon term." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

assay_base:normalization_method a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "normalization_method" ;
    rdfs:range linkml:String ;
    skos:definition "Method used for data normalization." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

assay_base:passage_number a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "passage_number" ;
    rdfs:range linkml:Integer ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

assay_base:replicates_per_donor a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "replicates_per_donor" ;
    rdfs:range linkml:Integer ;
    skos:definition "Number of biological replicates per donor." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

assay_base:substrate_type a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "substrate_type" ;
    rdfs:range owg:SubstrateTypeEnum ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

assay_base:unit a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "unit" ;
    rdfs:range assay_base:Unit ;
    skos:definition "The unit of measurement." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

assay_microschemas:mucus_layer_thickness a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "mucus_layer_thickness" ;
    rdfs:range assay_base:QuantityValue ;
    skos:definition "Thickness of the mucus gel layer in micrometers. TIER 2." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_microschemas> .

assay_microschemas:normalization_reference a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "normalization_reference" ;
    rdfs:range linkml:String ;
    skos:definition "Normalization reference (beta-actin, GAPDH, total EGFR)." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_microschemas> .

owg:AssayContextCapabilityEnum a owl:Class,
        linkml:EnumDefinition ;
    rdfs:label "AssayContextCapabilityEnum" ;
    owl:unionOf ( <https://w3id.org/EHS-Data-Standards/soma/AssayContextCapabilityEnum#in_vitro_only> <https://w3id.org/EHS-Data-Standards/soma/AssayContextCapabilityEnum#in_vivo_only> <https://w3id.org/EHS-Data-Standards/soma/AssayContextCapabilityEnum#in_vitro_or_in_vivo> ) ;
    skos:definition "Indicates what experimental contexts an assay class supports. Used to constrain valid study_subject types and enable context-appropriate slots." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> ;
    linkml:permissible_values <https://w3id.org/EHS-Data-Standards/soma/AssayContextCapabilityEnum#in_vitro_only>,
        <https://w3id.org/EHS-Data-Standards/soma/AssayContextCapabilityEnum#in_vitro_or_in_vivo>,
        <https://w3id.org/EHS-Data-Standards/soma/AssayContextCapabilityEnum#in_vivo_only> .

owg:OutcomeLevelEnum a owl:Class,
        linkml:EnumDefinition ;
    rdfs:label "OutcomeLevelEnum" ;
    owl:unionOf ( <https://w3id.org/EHS-Data-Standards/soma/OutcomeLevelEnum#individual> <https://w3id.org/EHS-Data-Standards/soma/OutcomeLevelEnum#population> ) ;
    skos:definition "Levels at which adverse outcomes manifest." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/aop_framework> ;
    linkml:permissible_values <https://w3id.org/EHS-Data-Standards/soma/OutcomeLevelEnum#individual>,
        <https://w3id.org/EHS-Data-Standards/soma/OutcomeLevelEnum#population> .

aop_framework:NamedThing a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "NamedThing" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom linkml:Uriorcurie ;
            owl:onProperty aop_framework:id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty aop_framework:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aop_framework:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aop_framework:description ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aop_framework:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty aop_framework:description ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aop_framework:id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aop_framework:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty aop_framework:name ] ;
    skos:definition "A generic entity with an identifier and name. Base class for all named entities in the schema." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/aop_framework> .

assay_base:StudySubject a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "StudySubject" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom assay_base:NamedEntity ;
            owl:onProperty assay_base:model_species ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:model_species ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:model_species ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:subject_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty assay_base:subject_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:subject_type ],
        aop_framework:NamedThing ;
    skos:definition "The subject of a study — what the assay is performed on. Subclasses capture different experimental contexts (model systems, living subjects, populations) with context-appropriate slots. The type of subject determines which slots are available, replacing the old mixin pattern." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

assay_base:protocol_type a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "protocol_type" ;
    rdfs:range linkml:String ;
    skos:definition "The specific type of protocol. Used to designate which concrete class (e.g., ImagingProtocol, StainingProtocol, SpirometryProtocol, MolecularAssayProtocol) is instantiated for polymorphic protocol slots." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

assay_base:subject_type a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "subject_type" ;
    rdfs:range linkml:String ;
    skos:definition "The specific type of study subject. Used to designate which concrete class (e.g., CellularSystem, InVivoSubject) is instantiated for polymorphic study_subject slots." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

aop_framework:aopwiki_id a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "aopwiki_id" ;
    rdfs:range linkml:String ;
    skos:definition "The AOP-Wiki identifier for this entity (e.g., \"AOP:411\" for an AOP, \"KE:1234\" for a key event)." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/aop_framework> .

aop_framework:id a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "id" ;
    rdfs:range linkml:Uriorcurie ;
    skos:definition "A unique identifier for the entity." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/aop_framework> .

aop_framework:name a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "name" ;
    rdfs:range linkml:String ;
    skos:definition "A human-readable name for the entity." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/aop_framework> .

assay_base:catalog_number a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "catalog_number" ;
    rdfs:range linkml:String ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

owg:DirectionalityEnum a owl:Class,
        linkml:EnumDefinition ;
    rdfs:label "DirectionalityEnum" ;
    owl:unionOf ( <https://w3id.org/EHS-Data-Standards/soma/DirectionalityEnum#normal> <https://w3id.org/EHS-Data-Standards/soma/DirectionalityEnum#reversed> <https://w3id.org/EHS-Data-Standards/soma/DirectionalityEnum#absent> <https://w3id.org/EHS-Data-Standards/soma/DirectionalityEnum#variable> ) ;
    skos:definition "Directionality of mucociliary transport." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_microschemas> ;
    linkml:permissible_values <https://w3id.org/EHS-Data-Standards/soma/DirectionalityEnum#absent>,
        <https://w3id.org/EHS-Data-Standards/soma/DirectionalityEnum#normal>,
        <https://w3id.org/EHS-Data-Standards/soma/DirectionalityEnum#reversed>,
        <https://w3id.org/EHS-Data-Standards/soma/DirectionalityEnum#variable> .

owg:EvidenceSupportEnum a owl:Class,
        linkml:EnumDefinition ;
    rdfs:label "EvidenceSupportEnum" ;
    owl:unionOf ( <https://w3id.org/EHS-Data-Standards/soma/EvidenceSupportEnum#strong> <https://w3id.org/EHS-Data-Standards/soma/EvidenceSupportEnum#moderate> <https://w3id.org/EHS-Data-Standards/soma/EvidenceSupportEnum#weak> <https://w3id.org/EHS-Data-Standards/soma/EvidenceSupportEnum#not_specified> ) ;
    skos:definition "Levels of evidence support for key event relationships." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/aop_framework> ;
    linkml:permissible_values <https://w3id.org/EHS-Data-Standards/soma/EvidenceSupportEnum#moderate>,
        <https://w3id.org/EHS-Data-Standards/soma/EvidenceSupportEnum#not_specified>,
        <https://w3id.org/EHS-Data-Standards/soma/EvidenceSupportEnum#strong>,
        <https://w3id.org/EHS-Data-Standards/soma/EvidenceSupportEnum#weak> .

owg:QuantitativeUnderstandingEnum a owl:Class,
        linkml:EnumDefinition ;
    rdfs:label "QuantitativeUnderstandingEnum" ;
    owl:unionOf ( <https://w3id.org/EHS-Data-Standards/soma/QuantitativeUnderstandingEnum#high> <https://w3id.org/EHS-Data-Standards/soma/QuantitativeUnderstandingEnum#moderate> <https://w3id.org/EHS-Data-Standards/soma/QuantitativeUnderstandingEnum#low> <https://w3id.org/EHS-Data-Standards/soma/QuantitativeUnderstandingEnum#not_specified> ) ;
    skos:definition "Levels of quantitative understanding for key event relationships." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/aop_framework> ;
    linkml:permissible_values <https://w3id.org/EHS-Data-Standards/soma/QuantitativeUnderstandingEnum#high>,
        <https://w3id.org/EHS-Data-Standards/soma/QuantitativeUnderstandingEnum#low>,
        <https://w3id.org/EHS-Data-Standards/soma/QuantitativeUnderstandingEnum#moderate>,
        <https://w3id.org/EHS-Data-Standards/soma/QuantitativeUnderstandingEnum#not_specified> .

assay_base:Assay a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "Assay" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:assay_date ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:has_exposure_condition ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:has_specified_output ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:study_subject ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_base:StudySubject ;
            owl:onProperty assay_base:study_subject ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:study_subject ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:informs_on_key_event ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:assay_date ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_base:AssayOutputMeasurement ;
            owl:onProperty assay_base:has_specified_output ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:has_specified_output ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_base:ExposureCondition ;
            owl:onProperty assay_base:has_exposure_condition ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:Date ;
            owl:onProperty assay_base:assay_date ],
        [ a owl:Restriction ;
            owl:allValuesFrom aop_framework:KeyEvent ;
            owl:onProperty assay_base:informs_on_key_event ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:informs_on_key_event ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:follows_protocols ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_base:Protocol ;
            owl:onProperty assay_base:follows_protocols ],
        aop_framework:NamedThing ;
    skos:definition "A planned process with the objective to produce information about biological state relevant to a Key Event in an Adverse Outcome Pathway. Assays are organized by the functional domain they assess (e.g., ciliary function, oxidative stress), and each domain-specific assay class contains named slots for the specific measurements it can produce. Assays inform on key events and contain the measurement data as named slots." ;
    skos:exactMatch OBI:0000070 ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

assay_base:Protocol a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "Protocol" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty assay_base:institution ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty assay_base:protocol_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:last_updated ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:Date ;
            owl:onProperty assay_base:last_updated ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:protocol_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty assay_base:protocol_author ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:protocol_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:protocol_version ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_base:Protocol ;
            owl:onProperty assay_base:sub_protocols ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty assay_base:equipment_required ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:publication_reference ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty assay_base:validation_status ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:institution ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:replicate_requirements ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:last_updated ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:validation_status ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:quality_control_criteria ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:publication_reference ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:quality_control_criteria ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty assay_base:quality_control_criteria ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:equipment_required ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:replicate_requirements ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:protocol_version ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty assay_base:publication_reference ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty assay_base:protocol_version ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:validation_status ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:institution ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:protocol_author ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:protocol_author ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:Integer ;
            owl:onProperty assay_base:replicate_requirements ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:sub_protocols ],
        aop_framework:NamedThing ;
    skos:definition "A detailed set of steps for how to perform a specific assay. Protocols ensure reproducibility across laboratories. Contains universal slots; domain-specific details are in protocol subclasses (ImagingProtocol, StainingProtocol, etc.). Protocols can reference other protocols via sub_protocols to represent composite workflows (e.g., sample preparation, wash steps, or post-processing protocols that are shared across assays)." ;
    skos:exactMatch OBI:0000272 ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

assay_base:study_subject a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "study_subject" ;
    rdfs:range assay_base:StudySubject ;
    skos:definition "The subject of the study — what the assay is performed on. Can be a ModelSystem (e.g., CellularSystem), an InVivoSubject, or a PopulationSubject. The type of subject determines which context slots are available." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

owg:CiliaryMotionPatternEnum a owl:Class,
        linkml:EnumDefinition ;
    rdfs:label "CiliaryMotionPatternEnum" ;
    owl:unionOf ( <https://w3id.org/EHS-Data-Standards/soma/CiliaryMotionPatternEnum#coordinated> <https://w3id.org/EHS-Data-Standards/soma/CiliaryMotionPatternEnum#dyskinetic> <https://w3id.org/EHS-Data-Standards/soma/CiliaryMotionPatternEnum#immotile> <https://w3id.org/EHS-Data-Standards/soma/CiliaryMotionPatternEnum#rotational> <https://w3id.org/EHS-Data-Standards/soma/CiliaryMotionPatternEnum#stiff> ) ;
    skos:definition "Patterns of ciliary motion." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_microschemas> ;
    linkml:permissible_values <https://w3id.org/EHS-Data-Standards/soma/CiliaryMotionPatternEnum#coordinated>,
        <https://w3id.org/EHS-Data-Standards/soma/CiliaryMotionPatternEnum#dyskinetic>,
        <https://w3id.org/EHS-Data-Standards/soma/CiliaryMotionPatternEnum#immotile>,
        <https://w3id.org/EHS-Data-Standards/soma/CiliaryMotionPatternEnum#rotational>,
        <https://w3id.org/EHS-Data-Standards/soma/CiliaryMotionPatternEnum#stiff> .

assay_base:AssayOutputMeasurement a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "AssayOutputMeasurement" ;
    rdfs:subClassOf aop_framework:NamedThing ;
    skos:definition "The measurement results produced by an assay. The specified output of a planned process. Each domain-specific assay class has a corresponding AssayOutputMeasurement subclass containing the named measurement slots for that assay type. This class represents the \"output\" in the Input/Process/Output model: what was measured and what values were obtained." ;
    skos:exactMatch IAO:0000109 ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

aop_framework:KeyEvent a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "KeyEvent" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aop_framework:downstream_key_events ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aop_framework:aopwiki_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom owg:BiologicalActionEnum ;
            owl:onProperty aop_framework:biological_action ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty aop_framework:biological_object ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:Uriorcurie ;
            owl:onProperty aop_framework:biological_process ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:Uriorcurie ;
            owl:onProperty aop_framework:occurs_in_cell_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aop_framework:level_of_biological_organization ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aop_framework:occurs_in_cell_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aop_framework:level_of_biological_organization ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty aop_framework:aopwiki_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aop_framework:occurs_in_anatomy ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aop_framework:biological_process ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aop_framework:biological_process ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aop_framework:aopwiki_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom aop_framework:KeyEvent ;
            owl:onProperty aop_framework:downstream_key_events ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aop_framework:biological_object ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aop_framework:occurs_in_anatomy ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aop_framework:upstream_key_events ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aop_framework:biological_action ],
        [ a owl:Restriction ;
            owl:allValuesFrom owg:BiologicalOrganizationLevelEnum ;
            owl:onProperty aop_framework:level_of_biological_organization ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aop_framework:occurs_in_cell_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aop_framework:biological_object ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:Uriorcurie ;
            owl:onProperty aop_framework:occurs_in_anatomy ],
        [ a owl:Restriction ;
            owl:allValuesFrom aop_framework:KeyEvent ;
            owl:onProperty aop_framework:upstream_key_events ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aop_framework:biological_action ],
        aop_framework:NamedThing ;
    skos:definition "A measurable change in biological state that is a step in an Adverse Outcome Pathway. Key Events represent the biological perturbations that assays measure to provide evidence for AOP-based mechanistic understanding. Key events can be Molecular Initiating Events (MIEs), intermediate Key Events, or Adverse Outcomes at the organism/population level." ;
    skos:exactMatch ECTO:1000000 ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/aop_framework> .

<https://w3id.org/EHS-Data-Standards/soma> a owl:Ontology ;
    rdfs:label "soma" ;
    dcterms:license "MIT" ;
    dcterms:title "SOMA Schema" ;
    rdfs:seeAlso <https://EHS-Data-Standards.github.io/soma> ;
    skos:definition """A LinkML data model for representing biological assays, measurements, and experimental protocols in the context of outcomes research. The schema is centered around ASSAYS that inform on Key Events in Adverse Outcome Pathways (AOPs), with named slots for specific measurements.
This is the main entry point that imports the AOP framework, assay base schema, and domain-specific assay microschemas.""" .

owg:BiologicalOrganizationLevelEnum a owl:Class,
        linkml:EnumDefinition ;
    rdfs:label "BiologicalOrganizationLevelEnum" ;
    owl:unionOf ( <https://w3id.org/EHS-Data-Standards/soma/BiologicalOrganizationLevelEnum#molecular> <https://w3id.org/EHS-Data-Standards/soma/BiologicalOrganizationLevelEnum#cellular> <https://w3id.org/EHS-Data-Standards/soma/BiologicalOrganizationLevelEnum#tissue> <https://w3id.org/EHS-Data-Standards/soma/BiologicalOrganizationLevelEnum#organ> <https://w3id.org/EHS-Data-Standards/soma/BiologicalOrganizationLevelEnum#organism> <https://w3id.org/EHS-Data-Standards/soma/BiologicalOrganizationLevelEnum#population> ) ;
    skos:definition "Levels of biological organization for key events." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/aop_framework> ;
    linkml:permissible_values <https://w3id.org/EHS-Data-Standards/soma/BiologicalOrganizationLevelEnum#cellular>,
        <https://w3id.org/EHS-Data-Standards/soma/BiologicalOrganizationLevelEnum#molecular>,
        <https://w3id.org/EHS-Data-Standards/soma/BiologicalOrganizationLevelEnum#organ>,
        <https://w3id.org/EHS-Data-Standards/soma/BiologicalOrganizationLevelEnum#organism>,
        <https://w3id.org/EHS-Data-Standards/soma/BiologicalOrganizationLevelEnum#population>,
        <https://w3id.org/EHS-Data-Standards/soma/BiologicalOrganizationLevelEnum#tissue> .

owg:CellCultureGrowthModeEnum a owl:Class,
        linkml:EnumDefinition ;
    rdfs:label "CellCultureGrowthModeEnum" ;
    owl:unionOf ( <http://purl.obolibrary.org/obo/CLO_0000028> <http://purl.obolibrary.org/obo/CLO_0000029> OBI:0600047 <https://w3id.org/EHS-Data-Standards/soma/CellCultureGrowthModeEnum#three_dimensional> <https://w3id.org/EHS-Data-Standards/soma/CellCultureGrowthModeEnum#organoid> <https://w3id.org/EHS-Data-Standards/soma/CellCultureGrowthModeEnum#spheroid> ) ;
    skos:definition "Cell culture growth modes." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> ;
    linkml:permissible_values <http://purl.obolibrary.org/obo/CLO_0000028>,
        <http://purl.obolibrary.org/obo/CLO_0000029>,
        OBI:0600047,
        <https://w3id.org/EHS-Data-Standards/soma/CellCultureGrowthModeEnum#organoid>,
        <https://w3id.org/EHS-Data-Standards/soma/CellCultureGrowthModeEnum#spheroid>,
        <https://w3id.org/EHS-Data-Standards/soma/CellCultureGrowthModeEnum#three_dimensional> .

owg:BiologicalActionEnum a owl:Class,
        linkml:EnumDefinition ;
    rdfs:label "BiologicalActionEnum" ;
    owl:unionOf ( <https://w3id.org/EHS-Data-Standards/soma/BiologicalActionEnum#increased> <https://w3id.org/EHS-Data-Standards/soma/BiologicalActionEnum#decreased> <https://w3id.org/EHS-Data-Standards/soma/BiologicalActionEnum#altered> <https://w3id.org/EHS-Data-Standards/soma/BiologicalActionEnum#impaired> <https://w3id.org/EHS-Data-Standards/soma/BiologicalActionEnum#disrupted> <https://w3id.org/EHS-Data-Standards/soma/BiologicalActionEnum#activated> <https://w3id.org/EHS-Data-Standards/soma/BiologicalActionEnum#inhibited> ) ;
    skos:definition "Types of biological changes or actions in key events." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/aop_framework> ;
    linkml:permissible_values <https://w3id.org/EHS-Data-Standards/soma/BiologicalActionEnum#activated>,
        <https://w3id.org/EHS-Data-Standards/soma/BiologicalActionEnum#altered>,
        <https://w3id.org/EHS-Data-Standards/soma/BiologicalActionEnum#decreased>,
        <https://w3id.org/EHS-Data-Standards/soma/BiologicalActionEnum#disrupted>,
        <https://w3id.org/EHS-Data-Standards/soma/BiologicalActionEnum#impaired>,
        <https://w3id.org/EHS-Data-Standards/soma/BiologicalActionEnum#increased>,
        <https://w3id.org/EHS-Data-Standards/soma/BiologicalActionEnum#inhibited> .

assay_base:NamedEntity a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "NamedEntity" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty aop_framework:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aop_framework:id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty aop_framework:id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aop_framework:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aop_framework:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:Uriorcurie ;
            owl:onProperty aop_framework:id ] ;
    skos:definition "A reference to an entity with an identifier and name. Used for cell_type, tissue_context, participant references, etc." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

owg:SampleTypeEnum a owl:Class,
        linkml:EnumDefinition ;
    rdfs:label "SampleTypeEnum" ;
    owl:unionOf ( <https://w3id.org/EHS-Data-Standards/soma/SampleTypeEnum#urine> <https://w3id.org/EHS-Data-Standards/soma/SampleTypeEnum#blood> <https://w3id.org/EHS-Data-Standards/soma/SampleTypeEnum#sputum> <https://w3id.org/EHS-Data-Standards/soma/SampleTypeEnum#balf> <https://w3id.org/EHS-Data-Standards/soma/SampleTypeEnum#nasal_epithelium> <https://w3id.org/EHS-Data-Standards/soma/SampleTypeEnum#bronchial_epithelium> <https://w3id.org/EHS-Data-Standards/soma/SampleTypeEnum#exhaled_breath_condensate> <https://w3id.org/EHS-Data-Standards/soma/SampleTypeEnum#biopsy> <https://w3id.org/EHS-Data-Standards/soma/SampleTypeEnum#sweat> ) ;
    skos:definition "Types of biological samples for in vivo assays." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> ;
    linkml:permissible_values <https://w3id.org/EHS-Data-Standards/soma/SampleTypeEnum#balf>,
        <https://w3id.org/EHS-Data-Standards/soma/SampleTypeEnum#biopsy>,
        <https://w3id.org/EHS-Data-Standards/soma/SampleTypeEnum#blood>,
        <https://w3id.org/EHS-Data-Standards/soma/SampleTypeEnum#bronchial_epithelium>,
        <https://w3id.org/EHS-Data-Standards/soma/SampleTypeEnum#exhaled_breath_condensate>,
        <https://w3id.org/EHS-Data-Standards/soma/SampleTypeEnum#nasal_epithelium>,
        <https://w3id.org/EHS-Data-Standards/soma/SampleTypeEnum#sputum>,
        <https://w3id.org/EHS-Data-Standards/soma/SampleTypeEnum#sweat>,
        <https://w3id.org/EHS-Data-Standards/soma/SampleTypeEnum#urine> .

owg:SubstrateTypeEnum a owl:Class,
        linkml:EnumDefinition ;
    rdfs:label "SubstrateTypeEnum" ;
    owl:unionOf ( <https://w3id.org/EHS-Data-Standards/soma/SubstrateTypeEnum#plastic> <https://w3id.org/EHS-Data-Standards/soma/SubstrateTypeEnum#collagen_coated> <https://w3id.org/EHS-Data-Standards/soma/SubstrateTypeEnum#matrigel> <https://w3id.org/EHS-Data-Standards/soma/SubstrateTypeEnum#fibronectin_coated> <https://w3id.org/EHS-Data-Standards/soma/SubstrateTypeEnum#laminin_coated> <https://w3id.org/EHS-Data-Standards/soma/SubstrateTypeEnum#transwell_insert> <https://w3id.org/EHS-Data-Standards/soma/SubstrateTypeEnum#hydrogel> <https://w3id.org/EHS-Data-Standards/soma/SubstrateTypeEnum#glass> <https://w3id.org/EHS-Data-Standards/soma/SubstrateTypeEnum#pdms> ) ;
    skos:definition "Types of cell culture substrates." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> ;
    linkml:permissible_values <https://w3id.org/EHS-Data-Standards/soma/SubstrateTypeEnum#collagen_coated>,
        <https://w3id.org/EHS-Data-Standards/soma/SubstrateTypeEnum#fibronectin_coated>,
        <https://w3id.org/EHS-Data-Standards/soma/SubstrateTypeEnum#glass>,
        <https://w3id.org/EHS-Data-Standards/soma/SubstrateTypeEnum#hydrogel>,
        <https://w3id.org/EHS-Data-Standards/soma/SubstrateTypeEnum#laminin_coated>,
        <https://w3id.org/EHS-Data-Standards/soma/SubstrateTypeEnum#matrigel>,
        <https://w3id.org/EHS-Data-Standards/soma/SubstrateTypeEnum#pdms>,
        <https://w3id.org/EHS-Data-Standards/soma/SubstrateTypeEnum#plastic>,
        <https://w3id.org/EHS-Data-Standards/soma/SubstrateTypeEnum#transwell_insert> .

owg:SupplementTypeEnum a owl:Class,
        linkml:EnumDefinition ;
    rdfs:label "SupplementTypeEnum" ;
    owl:unionOf ( CHEBI:23924 CHEBI:33281 CHEBI:35718 CHEBI:24621 CHEBI:33229 CHEBI:33709 CHEBI:18059 <https://w3id.org/EHS-Data-Standards/soma/SupplementTypeEnum#trace_element> <https://w3id.org/EHS-Data-Standards/soma/SupplementTypeEnum#attachment_factor> <https://w3id.org/EHS-Data-Standards/soma/SupplementTypeEnum#differentiation_factor> ) ;
    skos:definition "Categories of cell culture medium supplements." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> ;
    linkml:permissible_values CHEBI:18059,
        CHEBI:23924,
        CHEBI:24621,
        CHEBI:33229,
        CHEBI:33281,
        CHEBI:33709,
        CHEBI:35718,
        <https://w3id.org/EHS-Data-Standards/soma/SupplementTypeEnum#attachment_factor>,
        <https://w3id.org/EHS-Data-Standards/soma/SupplementTypeEnum#differentiation_factor>,
        <https://w3id.org/EHS-Data-Standards/soma/SupplementTypeEnum#trace_element> .

assay_base:has_specified_output a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "has_specified_output" ;
    rdfs:range assay_base:AssayOutputMeasurement ;
    skos:definition "The measurement results produced by this assay — the specified output of a planned process (OBI). Contains the domain-specific measurement values (e.g., beat frequency, cilia length for CiliaryFunctionAssay)." ;
    skos:exactMatch OBI:0000299 ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

assay_base:QuantityValue a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "QuantityValue" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:unit ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_base:Unit ;
            owl:onProperty assay_base:unit ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:value ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty assay_base:value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_base:unit ] ;
    skos:definition "A quantity with a numeric value and unit of measurement. Used for all measurement values in assays." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_base> .

[] a owl:Restriction ;
    rdfs:subClassOf assay_base:PopulationSubject ;
    owl:onProperty assay_base:subject_type ;
    owl:someValuesFrom assay_base:PopulationSubject .

[] a owl:Restriction ;
    rdfs:subClassOf assay_base:Protocol ;
    owl:onProperty assay_base:protocol_type ;
    owl:someValuesFrom assay_base:Protocol .

[] a owl:Restriction ;
    rdfs:subClassOf assay_base:CellularSystem ;
    owl:onProperty assay_base:subject_type ;
    owl:someValuesFrom assay_base:CellularSystem .

[] a owl:Restriction ;
    rdfs:subClassOf assay_base:ImagingProtocol ;
    owl:onProperty assay_base:protocol_type ;
    owl:someValuesFrom assay_base:ImagingProtocol .

[] a owl:Restriction ;
    rdfs:subClassOf assay_base:StainingProtocol ;
    owl:onProperty assay_base:protocol_type ;
    owl:someValuesFrom assay_base:StainingProtocol .

[] a owl:Restriction ;
    rdfs:subClassOf assay_base:StudySubject ;
    owl:onProperty assay_base:subject_type ;
    owl:someValuesFrom assay_base:StudySubject .

[] a owl:Restriction ;
    rdfs:subClassOf assay_base:SpirometryProtocol ;
    owl:onProperty assay_base:protocol_type ;
    owl:someValuesFrom assay_base:SpirometryProtocol .

[] a owl:Restriction ;
    rdfs:subClassOf assay_base:InVivoSubject ;
    owl:onProperty assay_base:subject_type ;
    owl:someValuesFrom assay_base:InVivoSubject .

[] a owl:Restriction ;
    rdfs:subClassOf assay_base:ModelSystem ;
    owl:onProperty assay_base:subject_type ;
    owl:someValuesFrom assay_base:ModelSystem .

[] a owl:Restriction ;
    rdfs:subClassOf assay_base:MolecularAssayProtocol ;
    owl:onProperty assay_base:protocol_type ;
    owl:someValuesFrom assay_base:MolecularAssayProtocol .

