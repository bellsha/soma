assay_microschemas:CFTRFunctionOutput a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "CFTRFunctionOutput" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_microschemas:inhibitor_sensitive_current ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_microschemas:sweat_chloride_concentration ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_microschemas:cftr_specific_current ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_microschemas:cftr_chloride_secretion ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_base:QuantityValue ;
            owl:onProperty assay_microschemas:cftr_forskolin_response ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_base:QuantityValue ;
            owl:onProperty assay_microschemas:inhibitor_sensitive_current ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_microschemas:cftr_forskolin_response ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_microschemas:nasal_potential_difference ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_microschemas:inhibitor_sensitive_current ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_base:QuantityValue ;
            owl:onProperty assay_microschemas:cftr_specific_current ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_microschemas:sweat_chloride_concentration ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_microschemas:nasal_potential_difference ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_base:QuantityValue ;
            owl:onProperty assay_microschemas:nasal_potential_difference ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_microschemas:cftr_chloride_secretion ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_base:QuantityValue ;
            owl:onProperty assay_microschemas:sweat_chloride_concentration ],
        [ a owl:Restriction ;
