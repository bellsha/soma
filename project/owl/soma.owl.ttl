            owl:onProperty assay_microschemas:reactive_oxygen_species ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_microschemas:antioxidant_capacity ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_microschemas:four_hydroxynonenal_level ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty assay_microschemas:protein_oxidation_markers ],
        assay_base:AssayOutputMeasurement ;
    skos:definition "Measurement results from an oxidative stress assay. Contains all surrogate markers for oxidative stress including ROS levels, lipid peroxidation, protein oxidation, DNA damage, and antioxidant capacity." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_microschemas> .

