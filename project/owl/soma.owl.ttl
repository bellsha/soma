        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_base:cell_type_ratios ],
        assay_base:AssayOutputMeasurement ;
    skos:definition "Measurement results from a ciliary function assay. Contains the measured values for ciliary beat frequency, active area, cilia morphology, and ciliated cell populations." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_microschemas> .

assay_microschemas:EGFRSignalingOutput a owl:Class,
