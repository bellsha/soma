            owl:onProperty assay_microschemas:cftr_chloride_secretion ],
        assay_base:AssayOutputMeasurement ;
    skos:definition "Measurement results from a CFTR function assay. Contains the measured values for CFTR-mediated chloride secretion, forskolin response, and related electrophysiology measurements." ;
    skos:inScheme <https://w3id.org/EHS-Data-Standards/assay_microschemas> .

assay_microschemas:CiliaryFunctionOutput a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "CiliaryFunctionOutput" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_microschemas:beat_frequency_hz ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_base:QuantityValue ;
            owl:onProperty assay_microschemas:beat_frequency_hz ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_microschemas:ciliary_beat_amplitude ],
