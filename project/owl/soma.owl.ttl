        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_microschemas:cilia_per_cell ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_base:QuantityValue ;
            owl:onProperty assay_microschemas:cilia_length ],
        [ a owl:Restriction ;
