            owl:onProperty assay_microschemas:beat_frequency_hz ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_microschemas:cilia_per_cell ],
        [ a owl:Restriction ;
            owl:allValuesFrom owg:CiliaryMotionPatternEnum ;
            owl:onProperty assay_microschemas:ciliary_motion_patterns ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty assay_microschemas:active_area_percentage ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty assay_microschemas:ciliary_beat_amplitude ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_base:QuantityValue ;
            owl:onProperty assay_microschemas:cilia_per_cell ],
        [ a owl:Restriction ;
