            owl:onProperty assay_microschemas:ciliary_motion_patterns ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_base:QuantityValue ;
            owl:onProperty assay_microschemas:percentage_ciliated_cells ],
        [ a owl:Restriction ;
            owl:allValuesFrom assay_base:QuantityValue ;
